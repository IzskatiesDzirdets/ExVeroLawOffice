<script>
(function(){
  /* Nav scroll */
  window.addEventListener('scroll', function(){
    document.getElementById('main-nav').classList.toggle('scrolled', window.scrollY > 60);
  });

  /* Mobile menu */
  var hb = document.getElementById('hamburger');
  var mm = document.getElementById('mobileMenu');
  function closeMobile(){
    hb.classList.remove('open'); mm.classList.remove('open');
    hb.setAttribute('aria-expanded','false'); document.body.style.overflow = '';
  }
  window.closeMobile = closeMobile;
  hb.addEventListener('click', function(){
    var o = hb.classList.toggle('open');
    mm.classList.toggle('open', o);
    hb.setAttribute('aria-expanded', o ? 'true' : 'false');
    document.body.style.overflow = o ? 'hidden' : '';
  });
  ['mm1','mm2','mm3','mm4'].forEach(function(id){
    var el = document.getElementById(id); if(el) el.addEventListener('click', closeMobile);
  });
  document.addEventListener('keydown', function(e){
    if(e.key === 'Escape' && mm.classList.contains('open')) closeMobile();
  });

  /* Language switcher */
  var currentLang = 'lv';
  window.setLang = function(lang){
    currentLang = lang;
    document.getElementById('btn-lv').classList.toggle('active', lang === 'lv');
    document.getElementById('btn-ru').classList.toggle('active', lang === 'ru');
    document.querySelectorAll('[data-' + lang + ']').forEach(function(el){
      var val = el.getAttribute('data-' + lang);
      if(el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
        el.placeholder = val;
      } else {
        el.innerHTML = val;
      }
    });
    // Update select options if booking rendered
    if(window._updateBookingLang) window._updateBookingLang(lang);
  };
  window.getCurrentLang = function(){ return currentLang; };

  /* Toast */
  window.showToast = function(msg){
    var t = document.getElementById('toast');
    t.textContent = msg; t.classList.add('show');
    setTimeout(function(){ t.classList.remove('show'); }, 3000);
  };

  /* Reveal on scroll */
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(x){ if(x.isIntersecting) x.target.classList.add('vis'); });
  }, {threshold:.08});
  document.querySelectorAll('.rv').forEach(function(el){ io.observe(el); });
})();
</script>

