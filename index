            const isAvail = avail(day);
            const cnt = onDay(d).length;
            const isSel = selDate === d;
            const isFull = cnt >= CFG.maxPerDay;
            const isWeekend = dt.getDay() === 0 || dt.getDay() === 6;
            let cls = 'cal-day';
            if(isPast || isWeekend) cls += ' past';
            else if(isSel) cls += ' sel';
            else if(isFull) cls += ' full';
            else if(isAvail) cls += ' avail';
            else cls += ' disabled';
            return (
              <div key={day} className={cls} onClick={() => { if(!isPast && !isWeekend && isAvail) setSD(d); }}>
                <div>{day}</div>
              </div>
            );
          })}
        </div>
        <div className="legend">
          <div className="leg-item"><div className="leg-dot" style={{background:'rgba(46,125,82,.4)',border:'1px solid rgba(46,125,82,.6)'}} />{tx.avail}</div>
          <div className="leg-item"><div className="leg-dot" style={{background:'rgba(139,46,46,.3)',border:'1px solid rgba(139,46,46,.5)'}} />{tx.full}</div>
          <div className="leg-item"><div className="leg-dot" style={{background:'var(--gold)'}} />{tx.sel}</div>
        </div>

        {selDate && (
          <div style={{marginTop:'1.4rem'}}>
            <label className="f-label">{tx.timeLabel}</label>
            <div className="time-grid">
              {TIMES.map(t => {
                const isTaken = taken.includes(t);
                return (
                  <div key={t}
                    className={'time-chip' + (selTime===t ? ' sel' : '') + (isTaken ? ' taken' : '')}
                    onClick={() => { if(!isTaken) setST(t); }}
                    title={isTaken ? (lang === 'lv' ? 'Aiznemts' : 'Занято') : t}>
                    {t}
                  </div>
                );
              })}
            </div>
          </div>
        )}
      </div>

      {/* RIGHT — Form */}
      <div className="b-panel">
        <div className="panel-ttl">
          <span className="panel-ttl-icon">&#128203;</span> {tx.formTitle}
        </div>

        {!selDate && <div className="info-chip">{tx.noDate}</div>}
        {selDate && selTime && <div className="sel-chip">&#128197; {tx.selDateTime(selDate, selTime)}</div>}
        {selDate && !selTime && <div className="info-chip">&#128336; {tx.noTime}</div>}
        {err && <div className="err-box">{err}</div>}

        <div className="f-row">
          <div className="f-group">
            <label className="f-label" htmlFor="bk-name">{tx.name}</label>
            <input id="bk-name" type="text" className="f-input" value={form.name}
              onChange={e => setF({...form, name:e.target.value})}
              placeholder={lang === 'lv' ? 'Jānis Bērziņš' : 'Иван Иванов'}
              autoComplete="name" />
          </div>
          <div className="f-group">
            <label className="f-label" htmlFor="bk-company">{tx.company}</label>
            <input id="bk-company" type="text" className="f-input" value={form.company}
              onChange={e => setF({...form, company:e.target.value})}
              placeholder={lang === 'lv' ? 'SIA Uznemums' : 'ООО Компания'} />
          </div>
        </div>
        <div className="f-row">
          <div className="f-group">
            <label className="f-label" htmlFor="bk-email">{tx.email}</label>
            <input id="bk-email" type="email" className="f-input" value={form.email}
              onChange={e => setF({...form, email:e.target.value})}
              placeholder="email@domain.lv" autoComplete="email" />
          </div>
          <div className="f-group">
            <label className="f-label" htmlFor="bk-phone">{tx.phone}</label>
            <input id="bk-phone" type="tel" className="f-input" value={form.phone}
              onChange={e => setF({...form, phone:e.target.value})}
              placeholder="+371 XXXXXXXX" autoComplete="tel" />
          </div>
        </div>
        <div className="f-group">
          <label className="f-label" htmlFor="bk-topic">{tx.topic}</label>
          <select id="bk-topic" className="f-select" value={form.topic}
            onChange={e => setF({...form, topic:e.target.value})}>
            {topics.map((t,i) => <option key={i} value={i===0?'':t}>{t}</option>)}
          </select>
        </div>
        <div className="f-group">
          <label className="f-label" htmlFor="bk-notes">{tx.notes}</label>
          <textarea id="bk-notes" className="f-area" value={form.notes}
            onChange={e => setF({...form, notes:e.target.value})}
            placeholder={tx.notesPlh} />
        </div>
        <button className="sub-btn" onClick={submit}
          disabled={sub || !selDate || !selTime}>
          {sub ? <><span className="spin" />{tx.submitting}</> : tx.submit}
        </button>
        <p style={{fontSize:'.68rem',color:'var(--gray)',textAlign:'center',marginTop:'.6rem',letterSpacing:'.04em'}}>
          {lang === 'lv' ? 'Sazināsimies 24h laikā · office@exvero.lv' : 'Свяжемся в течение 24ч · office@exvero.lv'}
        </p>
      </div>
    </div>
  );
}

ReactDOM.render(<BookingApp />, document.getElementById('booking-app'));
</script>

</body>
</html>
